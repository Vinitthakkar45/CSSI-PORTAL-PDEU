# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://cssi.pdpu.ac.in"
NEXTAUTH_SECRET=""        # openssl rand -base64 32

DOMAIN="cssi.pdpu.ac.in"

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB="cssi_db"
POSTGRES_USER="cssi_user"
POSTGRES_PASSWORD=""      # use a strong random password

# Inside Docker the host is the service name 'postgres'
DATABASE_URL="postgresql://cssi_user:REPLACE_PASSWORD@postgres:5432/cssi_db"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Inside Docker the host is the service name 'redis'
REDIS_URL="redis://redis:6379"

# ─── MinIO (in-house media storage) ───────────────────────────────────────────
MINIO_ENDPOINT="http://minio:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY=""       # use a strong random password
MINIO_BUCKET="cssi"

# Browser-visible base URL (nginx proxies /media/ → MinIO)
NEXT_PUBLIC_MEDIA_BASE_URL="https://cssi.pdpu.ac.in/media"
NEXT_PUBLIC_MINIO_BUCKET="cssi"

# ─── Email (nodemailer in Next.js app) ────────────────────────────────────────
# Dev: Gmail
EMAIL="your-email@gmail.com"
EMAIL_PASS=""             # Gmail app password
EMAIL_TRANSPORT="gmail"   # gmail | internal

# Production: PDPU internal relay (no credentials needed — set these instead)
# EMAIL_TRANSPORT="internal"
# EMAIL_HOST="10.30.1.35"
# EMAIL_PORT="25"

# ─── Cloudinary (disaster-recovery backup only) ───────────────────────────────
# Free tier: 25 GB — more than enough for a single compressed snapshot.
# NO LONGER used for serving media (MinIO handles that).
# Used ONLY by the backup container to store one nightly archive.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Backup schedule ──────────────────────────────────────────────────────────
BACKUP_CRON="0 2 * * 6"   # weekly Saturday at 2 AM

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER="admin"
GRAFANA_ADMIN_PASSWORD=""  # use a strong random password

# SMTP — Dev: Gmail app password (2FA must be enabled on the account)
GRAFANA_SMTP_HOST="smtp.gmail.com:587"
GRAFANA_SMTP_USER="your-email@gmail.com"
GRAFANA_SMTP_PASSWORD=""   # Gmail app password (not your login password)
GRAFANA_SMTP_FROM="your-email@gmail.com"

# SMTP — Production: PDPU internal mail relay (no auth needed)
# GRAFANA_SMTP_HOST="10.30.1.35:25"
# GRAFANA_SMTP_USER=""
# GRAFANA_SMTP_PASSWORD=""
# GRAFANA_SMTP_FROM="CSSI@sot.pdpu.ac.in"

# Comma-separated list — all receive alert emails
GRAFANA_ALERT_EMAILS="admin1@pdpu.ac.in,admin2@pdpu.ac.in,admin3@pdpu.ac.in"
