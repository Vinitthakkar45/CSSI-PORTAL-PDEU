# Example environment variables for the CSSI project
# Copy this file to `.env` and fill in real secret values.
# Do NOT commit actual secret values to version control.

# Database connection (Postgres). Keep the query string format if your DB requires sslmode or other params.
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>/<DB_NAME>?sslmode=require"

# NextAuth secret used to sign cookies/tokens. Use a long random string.
NEXTAUTH_SECRET="<NEXTAUTH_SECRET — generate a strong random value>"

# Base URL of the running Next.js app (used by NextAuth callbacks, OAuth redirects, etc.)
# For local dev use http://localhost:3000, in production use your deployed domain.
NEXTAUTH_URL="http://localhost:3000"

# Email account used for sending mails (transporter configuration in `lib/transporter.ts`).
# For Gmail App Passwords use the app-specific password here.
EMAIL="your-email@example.com"
EMAIL_PASS="<your_email_smtp_password_or_app_password>"

# Cloudinary credentials for image uploading. You can set either the individual fields
# or the single `CLOUDINARY_URL`. Keep these private.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="<cloud_name>"
CLOUDINARY_API_KEY="<cloudinary_api_key>"
CLOUDINARY_API_SECRET="<cloudinary_api_secret>"
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"

# Optional: useful runtime vars
# NODE_ENV=development
# PORT=3000

# Notes:
# - Copy this file to `.env` and replace placeholder values with real ones.
# - Keep `.env` out of source control. Consider using a secrets manager for production.